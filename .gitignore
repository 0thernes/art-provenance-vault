htmlcov/

# Local ledger working data (manifests are committed deliberately, not by glob)
vault/assets/
*.tmp

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# Secrets — never commit keys
*.pem
*.key
*.p12
.env
.env.*

# Logs — keep the directory (.gitkeep) but not log files themselves
logs/*.log
logs/*.log.*

# SQLite manifest index (rebuildable from the ledger; never commit)
vault/index.db

# register/verify smoke-test artifact (CI + local)
sample.bin
